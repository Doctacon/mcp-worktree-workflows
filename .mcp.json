{
    "mcpServers": {
      "worktree-voting": {
        "type": "stdio",
        "command": "uv",
        "args": [
            "run",
            "--no-project",
            "--with",
            "fastmcp",
            "./mcp-servers/worktree_workflows.py"
        ],
        "env": {}
      },
      "sqlmesh": {
        "type": "stdio",
        "command": "uv",
        "args": [
            "run",
            "--no-project",
            "--with",
            "fastmcp",
            "--with",
            "sqlmesh",
            "--with",
            "pyyaml",
            "./mcp-servers/sqlmesh_server.py"
        ],
        "env": {
            "SQLMESH_STATE_DIR": "./.sqlmesh_state"
        }
      },
      "duckdb": {
        "type": "stdio",
        "command": "uv",
        "args": [
            "run",
            "--no-project",
            "--with",
            "fastmcp",
            "--with",
            "duckdb",
            "--with",
            "pandas",
            "./mcp-servers/duckdb_server.py"
        ],
        "env": {
            "DUCKDB_STATE_DIR": "./.duckdb_state"
        }
      },
      "dagster": {
        "type": "stdio",
        "command": "uv",
        "args": [
            "run",
            "--no-project",
            "--with",
            "fastmcp",
            "--with",
            "dagster",
            "--with",
            "pyyaml",
            "./mcp-servers/dagster_server.py"
        ],
        "env": {
            "DAGSTER_STATE_DIR": "./.dagster_state"
        }
      },
      "dlt": {
        "type": "stdio",
        "command": "uv",
        "args": [
            "run",
            "--no-project",
            "--with",
            "fastmcp",
            "--with",
            "dlt",
            "--with",
            "duckdb",
            "./mcp-servers/dlt_server.py"
        ],
        "env": {
            "DLT_STATE_DIR": "./.dlt_state"
        }
      },
      "soda": {
        "type": "stdio",
        "command": "uv",
        "args": [
            "run",
            "--no-project",
            "--with",
            "fastmcp",
            "--with",
            "soda-core",
            "--with",
            "soda-core-duckdb",
            "--with",
            "pyyaml",
            "./mcp-servers/soda_server.py"
        ],
        "env": {
            "SODA_DIR": "./soda"
        }
      },
      "docker": {
        "type": "stdio",
        "command": "uv",
        "args": [
            "run",
            "--no-project",
            "--with",
            "fastmcp",
            "--with",
            "docker",
            "./mcp-servers/docker_server.py"
        ],
        "env": {
            "DOCKER_HOST": "unix:///Users/crlough/.colima/default/docker.sock"
        }
      },
      "ElevenLabs": {
          "type": "stdio",
          "command": "uvx",
          "args": [
            "elevenlabs-mcp"
          ],
          "env": {
            "ELEVENLABS_API_KEY": "<sample-api-key>"
          }
        }
    }
}